{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RefBoard",
  "version": "0.1.0",
  "identifier": "com.refboard.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "RefBoard",
        "width": 1100,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "fkrn75",
    "copyright": "© 2026 fkrn75",
    "category": "Productivity",
    "shortDescription": "PureRef 호환 레퍼런스 이미지 보드",
    "longDescription": "이미지를 모아 자유롭게 배치하는 레퍼런스 보드. .refb 저장·웹 공유·드로잉·정렬·크롭을 지원합니다.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
