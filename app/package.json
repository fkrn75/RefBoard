{
  "name": "refboard-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "RefBoard - PureRef 호환 레퍼런스 보드 (웹 캔버스 본체, 나중에 Tauri로 감쌈)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/stamp-sw.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,css,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,css,html,json}\"",
    "tauri": "tauri"
  },
  "dependencies": {
    "@pixi/gif": "^3.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "fflate": "^0.8.3",
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
